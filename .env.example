# Copy to .env and set values. Do not commit .env.
# Required for: docker-compose up

POSTGRES_USER=payroute
POSTGRES_PASSWORD=
POSTGRES_DB=payroute_db

REDIS_PASSWORD=

WEBHOOK_SECRET=
JWT_SECRET=

PROVIDER_CALLBACK_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:5173

# Optional: payment limits (defaults in code)
# MAX_AMOUNT_PER_TRANSACTION=100000000
# MAX_DAILY_VOLUME_PER_ACCOUNT=500000000
# MAX_PAYMENTS_PER_ACCOUNT_PER_DAY=50

# Optional: retention (defaults: idempotency 24h, webhook events 90 days)
# WEBHOOK_EVENTS_RETENTION_DAYS=90
